# --- Database (existing mote-db Postgres, moteteam schema) ---
DATABASE_URL=postgresql://user:password@host:5432/mote-db

# --- better-auth ---
# Generate a strong secret: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Public base URL (local: http://localhost:3005 ; prod: https://team.motekreatif.com)
BETTER_AUTH_URL=http://localhost:3005

# --- Access control ---
# Bootstrap admins (comma-separated). These emails may self-register (via seed)
# and receive the admin role. Everyone else must be invited.
ADMIN_EMAILS=motekreatif@gmail.com

# --- Seed first admin (npm run seed:admin) ---
SEED_ADMIN_EMAIL=motekreatif@gmail.com
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=Nanan

# --- Cloudflare R2 (file upload). Kosongkan semua = mock mode (public/uploads) ---
# File diserve lewat proxy auth-gated /api/r2/<key> (bucket privat, TANPA public URL).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT=
# Optional: kalau mau serve via URL publik (r2.dev/custom domain) alih-alih proxy.
# R2_PUBLIC_URL=

# --- Windsor.ai (performa organic IG/TikTok klien) ---
WINDSOR_API_KEY=

# --- KOL scraper proxy (Cloudflare WARP SOCKS5 exit-IP, dodge IG/TikTok block) ---
# Prod (container → host bridge gateway): socks5h://172.18.0.1:40000
# Local dev: SSH tunnel `-L 40000:127.0.0.1:40000` lalu socks5h://127.0.0.1:40000
# Kosong = tombol Scrape return null (team input manual).
SCRAPE_PROXY_URL=

# --- Meta Graph API token (paid ads insights). Long-lived user token, extend via Token Debugger ---
META_ACCESS_TOKEN=

# --- SMTP (email notif: task assignment + deadline reminder) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=Mote Team
SMTP_FROM_EMAIL=
# Secret guarding GET /api/cron/reminders?secret=... (trigger daily via cron/UptimeRobot)
CRON_SECRET=

# --- Anti-stuck self-ping (optional override) ---
# HEALTH_PING_URL=http://127.0.0.1:3005/api/health
